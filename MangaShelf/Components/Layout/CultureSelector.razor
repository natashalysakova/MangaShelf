    </MudSelect>  *@
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="m-0 p-0">
    <MudIcon 
        Icon="@Icons.Material.Filled.Language" Color="Color.Primary"
        Size="Size.Medium" Class="m-0 p-0" />
    @foreach (var culture in LocalizationService.SupportedCultures)
    {
        <MudButton OnClick="@(async () => { selectedCulture = culture; await ApplySelectedCultureAsync(); })" Color="Color.Inherit" Variant="Variant.Text" Class="m-0 p-0">
            @culture.TwoLetterISOLanguageName
        </MudButton>
    }
</MudStack>

@code
{
        private CultureInfo? selectedCulture;

    protected override void OnInitialized()
    {
        selectedCulture = CultureInfo.CurrentCulture;
    }

    private async Task ApplySelectedCultureAsync()
    {
        if (CultureInfo.CurrentCulture != selectedCulture)
        {
            var uri = new Uri(Navigation.Uri)
                .GetComponents(UriComponents.PathAndQuery, UriFormat.UriEscaped);
            var cultureEscaped = Uri.EscapeDataString(selectedCulture.Name);
            var uriEscaped = Uri.EscapeDataString(uri);

            Navigation.NavigateTo(
                $"Culture/Set?culture={cultureEscaped}&redirectUri={uriEscaped}",
                forceLoad: true);
        }
    }
}