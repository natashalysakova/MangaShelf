@page "/preorders"
@using MangaShelf.BL.Services
@using System.Security.Claims
@using MangaShelf.Components.Elements.SmallCard
@using MangaShelf.DAL.Models

@inherits UserContextComponent

@inject IUserLibraryService UserLibraryService
@inject IUiLocalizationService Localizer
<h3>@Localizer["Preorders"]</h3>

<style>
    .expired-preorder {
        /*outline: 5px solid red !important;
        outline-offset: -5px;  or -5px if you want it drawn inside */
        background-color: rgba(255, 0, 0, 0.3) !important;
    }

    .normal-preorder {
        background-color: rgba(255, 255, 255, 0.1) !important;
    }

    .preorder-image{
        width: 100%;
        height: auto;
    }
</style>

@if (UserLibraryDto != null)
{
    <MudGrid>
        <MudItem sm="12" md="8">
            <MudPaper Class="paper-manga-panel p-4" Elevation="0">
                @if (!UserLibraryDto.Volumes.Any())
                {
                    <MudItem sm="12">
                        <MudAlert Severity="Severity.Normal">@Localizer["NoPreorders"]</MudAlert>
                    </MudItem>
                }
                <MudGrid>
                    @foreach (var preorder in UserLibraryDto.Volumes)
                    {
                        var cardClass = "" + (preorder.IsPreorderDue ? "expired-preorder" :
               "normal-preorder");
                        <MudItem xs="6" sm="3" md="2" >
                            <MudStack Spacing="1" AlignItems="AlignItems.Center" class="@cardClass">
                                <div class="preorder-image">
                                    <SmallCard ShowButtons="true" VolumeId="@preorder.VolumeId"
                                               OnStatusChange="@ReloadUserLibrary" />

                                </div>
                                @{
                                    string text;
                                    @if (preorder.IsPreorderDue)
                                    {
                                        text = @Localizer["PreorderIsDue"];
                                    }
                                    else
                                    {
                                        text = @Localizer["Release"];
                                    }
                                }

                                <MudTooltip Text="@text" Arrow="true" Color="Color.Dark">

                                @if (preorder.IsPreorderDue)
                                {
                                    <MudText Color="Color.Error">@preorder.ReleaseDate?.ToString("d")</MudText>
                                }
                                else if (preorder.DaysTillRelease == 0)
                                {
                                    <MudText Color="Color.Success">@Localizer["Today"]</MudText>
                                }
                                else
                                {
                                    <MudText>@preorder.ReleaseDate?.ToString("d")</MudText>
                                }
                                </MudTooltip>
                            </MudStack>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        </MudItem>
        <MudItem sm="12" md="4">
            <MudPaper Class="paper-manga-panel p-4" Elevation="0">
                <VolumeHistoryView VolumeHistory="UserLibraryDto.Updates" GroupedByDate="true" />
            </MudPaper>
        </MudItem>
    </MudGrid>
}


@if (errorMessage != null)
{
    <MudText Color="Color.Error">@errorMessage</MudText>
}

@code {
    [CascadingParameter]
    public required Task<AuthenticationState> AuthStateTask { get; set; }

    private UserLibraryDto? UserLibraryDto;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        await LoadUserLibrary();
    }

    private async Task ReloadUserLibrary(VolumeStatus status)
    {
        await LoadUserLibrary();
    }

    private async Task LoadUserLibrary()
    {
        try
        {
            var userId = await GetUserId();
            if (userId != null)
            {
                UserLibraryDto = await UserLibraryService.GetUserPreorders(userId);

                errorMessage = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while loading preorders. " + ex.Message;
        }
    }

    private string FormatDays(int days)
    {
        var lastDigit = days % 10;
        if (lastDigit == 1 && days != 11)
        {
            return Localizer["OneDay"].Value.Replace("{count}", days.ToString());
        }
        else if (lastDigit >= 2 && lastDigit <= 4 && (days < 10 || days > 20))
        {
            return Localizer["FewDays"].Value.Replace("{count}", days.ToString());
        }
        else
        {
            return Localizer["Days"].Value.Replace("{count}", days.ToString());
        }
    }
}
