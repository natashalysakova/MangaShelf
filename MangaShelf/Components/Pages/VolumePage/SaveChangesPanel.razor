@inject IUiLocalizationService Localizer
@inject NavigationManager Navigation

<MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudButton OnClick="NavigateBack" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">
        @Localizer["BackToList"]
    </MudButton>

    @if (HasChanges)
    {
        
    <MudButton ButtonType="ButtonType.Submit" Color="Color.Primary" Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.Save">
        @Localizer["SaveChanges"]
    </MudButton>
    }
    else
    {
        <MudButton  OnClick="NavigateBack" Color="Color.Warning" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Close">
            @Localizer["Close"]
        </MudButton>

    }
    </MudStack>

@code {
    [Parameter]
    public bool HasChanges { get; set; } = true;
    
    [Parameter]
    [EditorRequired]
    public required string VolumePublicId { get; set; }

    private void NavigateBack(MouseEventArgs args)
    {
        Navigation.NavigateTo("/volume/" + VolumePublicId);
    }
}