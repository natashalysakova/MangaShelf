@using MangaShelf.DAL.Models
@using System.Security.Claims
@using System.Threading.Tasks

@inject IVolumePageLocalizationService Localizer

<MudStack Class="mb-3">
    <MudStack Row Breakpoint="Breakpoint.SmAndDown">
        @if (Volume.Series.Type != SeriesType.Unknown)
        {
            <MudTextField Variant="Variant.Filled" Label="@Localizer["SeriesType"]" ReadOnly="true" ShrinkLabel="true"
                          Value="@Localizer[Volume.Series.Type]"></MudTextField>
        }

        <MudTextField Variant="Variant.Filled" Label="@Localizer["Author"]" ReadOnly="true" ShrinkLabel="true"
                      FullWidth="true" Value="@string.Join(", ", @Volume.Series.Authors)"></MudTextField>
    </MudStack>

    <MudStack Row Breakpoint="Breakpoint.SmAndDown">
        <MudTextField Variant="Variant.Filled" Label="@Localizer["Publisher"]" ReadOnly="true"
                      Value="@Volume.Series.Publisher.Name"></MudTextField>

        <MudTextField Mask="@(new PatternMask("000-000-0000-00-0"))" Variant="Variant.Filled" Label="@Localizer["ISBN"]"
                      ReadOnly="true" Value="@Volume.ISBN">
        </MudTextField>

    </MudStack>

    <MudStack Row>
        <MudTextField Variant="Variant.Filled" Label="@Localizer["Status"]" ReadOnly="true"
                      Value="@Localizer[Volume.Series.Status]"></MudTextField>
        @if (Volume.Series.Status != SeriesStatus.OneShot)
        {
            <MudTextField Variant="Variant.Filled" Label="@Localizer["VolumeNumber"]" ReadOnly="true"
                          Value="@Volume.Number"></MudTextField>
            @if (Volume.Series.TotalVolumes > 0)
            {
                <MudTextField Variant="Variant.Filled" Label="@Localizer["TotalVolumes"]" ReadOnly="true"
                              Value="@Volume.Series.TotalVolumes"></MudTextField>
            }
        }

        <MudTextField Variant="Variant.Filled" Label="@Localizer["Age"]" ReadOnly="true" Value="@Volume.AgeRestriction">
        </MudTextField>

    </MudStack>
    @if (Volume.IsPreorder)
    {
        <MudItem>
            <MudAlert Severity="Severity.Warning" Elevation="0">
                @Localizer["ThisIsPreorderVolume"]
                @Volume.ReleaseDate?.ToString("dd.MM.yyyy")
            </MudAlert>
        </MudItem>
    }
    <MudStack Row>
        <MudTextField ShrinkLabel="true" Variant="Variant.Filled" Label="@Localizer["PreorderStarted"]" ReadOnly="true"
                      Value="@Volume.PreorderStart?.ToString("dd.MM.yyyy")">
        </MudTextField>
        <MudTextField Variant="Variant.Filled" Label="@Localizer["Released"]" ReadOnly="true"
                      Value="@Volume.ReleaseDate?.ToString("dd.MM.yyyy")"></MudTextField>
    </MudStack>
    <MudItem>
        <LongDescriptionText Text="@Volume.Description" />
    </MudItem>
</MudStack>

@code {
    [Parameter, EditorRequired]
    public VolumeDto Volume { get; set; }
}